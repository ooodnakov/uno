DATABASE_URL="postgresql://one:one_password@postgres:5432/one_game?schema=public"
SESSION_SECRET="change-me"
NODE_ENV="development"
PORT="3000"
HOSTNAME="0.0.0.0"
PUBLIC_APP_URL="http://localhost:3000"

# Development-only in-memory persistence. Set to 1 to run without PostgreSQL.
# Seeds users: host/password123 and guest/password123.
ONE_LOCAL_MEMORY="0"

# Development-only Socket.IO scaffold user. Leave empty in normal use.
DEV_SOCKET_USER_ID=""
DEV_SOCKET_DISPLAY_NAME="Developer"
